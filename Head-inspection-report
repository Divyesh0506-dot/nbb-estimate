<!DOCTYPE html>
<html>
<head>
    <title>Inspection Letter Generator</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <style>
        body {
            font-family: Arial, sans-serif;
            padding: 20px;
        }
        .container {
            max-width: 700px;
            margin: auto;
        }
        input {
            padding: 8px;
            width: 100%;
            margin-bottom: 10px;
            font-size: 16px;
        }
        button {
            padding: 10px;
            font-size: 16px;
            margin-right: 10px;
            cursor: pointer;
        }
    </style>
</head>
<body>

<div class="container">
    <h2>NEW BHARAT BORING AND GENERAL ENGINEERING WORKS</h2>
    <p>Turn by Tractor Centre, Opp. Tigraniya Factory Dwarka, Mumbai Agra Road, Nashik-422001.</p>

    <hr>

    <label><b>Date:</b></label>
    <input type="date" id="date">

    <label><b>Vehicle Number:</b></label>
    <input type="text" id="vehicle" placeholder="Enter Vehicle Number">

    <br>

    <button onclick="generatePDF()">Create PDF</button>
    <button onclick="sendWhatsApp()">Send on WhatsApp</button>
</div>

<script>
let pdfBlob;

async function generatePDF() {
    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();

    const date = document.getElementById("date").value;
    const vehicle = document.getElementById("vehicle").value;

    doc.setFontSize(12);

    doc.text("NEW BHARAT BORING AND GENERAL ENGINEERING WORKS", 10, 10);
    doc.text("Turn by Tractor Centre, Opp. Tigraniya Factory Dwarka,", 10, 16);
    doc.text("Mumbai Agra Road, Nashik-422001.", 10, 22);

    doc.text("Date: " + date, 150, 30);

    doc.text("To,", 10, 40);
    doc.text("The Workshop Manager,", 10, 46);
    doc.text("Seva Trucking Private Limited,", 10, 52);
    doc.text("Vilholi – Nashik.", 10, 58);

    doc.text("SUBJECT: Inspection of Cylinder Head components of vehicle registration number " + vehicle, 10, 70);

    doc.text("Respected Sir,", 10, 80);

    doc.text("We have inspected the cylinder head of the above-mentioned vehicle.", 10, 90);
    doc.text("It is observed that there is a warpage of 0.20 mm between cylinder no.1 and no.4.", 10, 96);
    doc.text("Also, intake and exhaust valves leakages observed.", 10, 102);

    doc.text("Hence it is recommended for Re-conditioning and Re-surfacing of Cylinder Head.", 10, 112);

    doc.text("CONCLUSION:", 10, 122);
    doc.text("Cylinder Head Inlet and Exhaust valves need replacement.", 10, 128);
    doc.text("Inlet valves: 6 Nos + Exhaust valves: 6 Nos + Valve Oil Seals: 12 Nos.", 10, 134);

    doc.text("Yours sincerely,", 140, 160);
    doc.text("ALL TYPES OF ENGINE & HEAD REPAIRING AND REBUILDING WORKS", 10, 180);

    pdfBlob = doc.output("blob");
    doc.save("Inspection_Letter_" + vehicle + ".pdf");
}

function sendWhatsApp() {
    if (!pdfBlob) {
        alert("Please create PDF first!");
        return;
    }

    const file = new File([pdfBlob], "Inspection_Letter.pdf", { type: "application/pdf" });

    if (navigator.share) {
        navigator.share({
            files: [file],
            title: "Inspection Letter",
            text: "Please find attached inspection letter."
        });
    } else {
        alert("Sharing not supported on this device. Open from mobile browser.");
    }
}
</script>

</body>
</html>
